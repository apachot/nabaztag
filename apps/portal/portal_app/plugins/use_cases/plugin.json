{
  "plugin_id": "use_cases",
  "label": "Laboratoire d'usages",
  "description": "Scènes expressives, improvisation, radio et scénarios Ztamp pour explorer rapidement de nouveaux usages.",
  "category": "experience",
  "default_enabled": true,
  "experimental": false,
  "hooks": [
    {
      "pipeline": "rabbit.detail.panels",
      "handler": "handlers.build_detail_panel"
    },
    {
      "pipeline": "rabbit.performance.before_queue",
      "handler": "handlers.before_performance_queue"
    },
    {
      "pipeline": "rabbit.performance.after_queue",
      "handler": "handlers.after_performance_queue"
    }
  ]
}
