#!/usr/bin/expect -f

set timeout 60

if {$argc < 3} {
    puts stderr "usage: ssh_with_password.expect <password> <host> <remote_command>"
    exit 2
}

set password [lindex $argv 0]
set host [lindex $argv 1]
set remote_command [lindex $argv 2]

spawn ssh -o StrictHostKeyChecking=no $host $remote_command
expect {
    "password:" {
        send -- "$password\r"
        exp_continue
    }
    eof
}
