#!/usr/bin/expect -f

set timeout 300

if {$argc < 2} {
    puts stderr "usage: spawn_with_password.expect <password> <command> [arg ...]"
    exit 2
}

set password [lindex $argv 0]
set command [lrange $argv 1 end]

eval spawn $command
expect {
    "password:" {
        send -- "$password\r"
        exp_continue
    }
    eof
}
